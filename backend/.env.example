# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here-change-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://jusmonitor:jusmonitor_dev_password@localhost:5432/jusmonitor
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# Security
SECURITY_HEADERS_ENABLED=true
MAX_PAYLOAD_SIZE_MB=10
INPUT_VALIDATION_ENABLED=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_AI_PER_MINUTE=10

# HTTP Compression
COMPRESSION_ENABLED=true
COMPRESSION_MINIMUM_SIZE=500
COMPRESSION_LEVEL=6

# HTTP Caching
CACHE_ENABLED=true
CACHE_DEFAULT_MAX_AGE=0
CACHE_STATIC_MAX_AGE=86400
CACHE_API_MAX_AGE=60

# Chatwit Integration
CHATWIT_API_URL=https://api.chatwit.com/v1
CHATWIT_API_KEY=your-chatwit-api-key
CHATWIT_WEBHOOK_SECRET=your-chatwit-webhook-secret
CHATWIT_RATE_LIMIT_PER_MINUTE=100

# Certificate Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPT_KEY=your-fernet-key-here

# MNI / Tribunal Integration
MNI_WSDL_CACHE_PATH=/tmp/zeep_cache.db
MNI_REQUEST_TIMEOUT=60
MNI_MAX_FILE_SIZE_MB=5

# DataJud Integration
DATAJUD_API_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_API_KEY=your-datajud-api-key
DATAJUD_CERT_PATH=/path/to/certificate.pem
DATAJUD_CERT_KEY_PATH=/path/to/certificate-key.pem
DATAJUD_RATE_LIMIT_PER_HOUR=100
DATAJUD_BATCH_SIZE=100
DATAJUD_SYNC_INTERVAL_HOURS=6

# AI Providers - OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# AI Providers - Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_MAX_TOKENS=4096

# AI Providers - Google
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-pro

# LiteLLM Configuration
LITELLM_FALLBACK_ENABLED=true
LITELLM_RETRY_ATTEMPTS=3
LITELLM_TIMEOUT_SECONDS=60

# Embeddings
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=50

# Taskiq Workers
TASKIQ_WORKERS=4
TASKIQ_MAX_RETRIES=3
TASKIQ_RETRY_DELAY_SECONDS=60

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@jusmonitor.com

# Monitoring
PROMETHEUS_ENABLED=true
SENTRY_DSN=your-sentry-dsn

# Storage (for backups and exports)
STORAGE_TYPE=local
STORAGE_PATH=/var/lib/jusmonitor/storage
# For S3:
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=jusmonitor-storage
# AWS_REGION=us-east-1
